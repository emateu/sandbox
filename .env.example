# Copy to .env (gitignored). Never commit.

# Container user. Required — read them off the host, don't guess:
#   HOST_UID=$(id -u)   HOST_GID=$(id -g)   USERNAME=$(whoami)
HOST_UID=
HOST_GID=
USERNAME=

# Loopback port for the promptless sshd (editor/remote access)
SANDBOX_SSH_PORT=2222

# From `claude setup-token` on the host — or manage it with tools/oauth-token (see
# its README). When tools/oauth-token/.tokens.json exists, the container refreshes
# this automatically and the value here is only a fallback. Secret.
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub fine-grained PAT (Contents + Pull requests RW on the agent's repos). Secret.
GH_TOKEN=

# Commit identity inside the sandbox
GIT_USER_NAME="Your Name"
GIT_USER_EMAIL=you@example.com

# Repos the sandbox works on: paths relative to ~/Code, space-separated. Copied
# in at startup, working tree as-is — .envs included. The host stays read-only;
# changes leave via git push. Edit the list, recreate the container.
SANDBOX_REPOS="myorg/api client-site"

# Dirs skipped while copying, matched at any depth. Empty copies everything.
# macOS-built artifacts (node_modules, .venv) are useless on Linux anyway.
SANDBOX_COPY_EXCLUDES="node_modules"

# jira-cli, all optional. Token from id.atlassian.com -> Security; secret.
# With the first four set, the entrypoint generates the jira config on boot.
# Project/board are just defaults; board falls back to None.
JIRA_API_TOKEN=
JIRA_SERVER=https://yourcompany.atlassian.net
JIRA_LOGIN=you@example.com
JIRA_PROJECT=
JIRA_BOARD=
