# Copy to .env (gitignored). Never commit.
HOST_UID=1000     # id -u
HOST_GID=1000     # id -g
USERNAME=you      # whoami

# Private key for git in the sandbox; matching .pub must exist next to it
SSH_KEY=/home/you/.ssh/id_ed25519

# From `claude setup-token` on the host. Secret.
CLAUDE_CODE_OAUTH_TOKEN=
