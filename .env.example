# Copy to .env (gitignored). Never commit.

# Container user. Required — read them off the host, don't guess:
#   HOST_UID=$(id -u)   HOST_GID=$(id -g)   USERNAME=$(whoami)
HOST_UID=
HOST_GID=
USERNAME=

# From `claude setup-token` on the host — or manage it with tools/oauth-token (see
# its README). When tools/oauth-token/.tokens.json exists, the container refreshes
# this automatically and the value here is only a fallback. Secret.
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub fine-grained PAT (Contents + Pull requests RW on the agent's repos). Secret.
GH_TOKEN=

# Commit identity inside the sandbox
GIT_USER_NAME="Your Name"
GIT_USER_EMAIL=you@example.com
